# ============================================================
# SENTINEL INTELLIGENCE — Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# ============================================================

# --- Gemini / Google AI Studio ---
# Get your API key from: https://aistudio.google.com
GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-2.5-flash-lite

# --- API Security ---
# Generate a random key: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=change_me_to_a_random_32_char_string

# --- Server ---
# Bind to 0.0.0.0 so Tailscale clients can reach it.
# Tailscale firewall is the network perimeter — no public exposure.
API_HOST=0.0.0.0
API_PORT=8000

# --- Tailscale ---
# Your server's Tailscale IP. Find it with: tailscale ip -4
TAILSCALE_IP=100.x.x.x

# --- Database ---
# Use an absolute path for reliability when run from cron.
DB_PATH=/home/ubuntu/sentinel/sentinel.db

# --- Frontend ---
# Absolute path to the frontend directory (served by FastAPI).
FRONTEND_DIR=/home/ubuntu/sentinel/frontend

# --- Data Retention ---
# Findings older than this many days are permanently deleted.
RETENTION_DAYS=7

# --- Collector ---
# Max concurrent Gemini API calls per collector run.
GEMINI_RATE_LIMIT=20
# Max characters of raw text sent to Gemini per item.
RAW_TEXT_MAX_CHARS=1500
# Minimum raw text length to consider for analysis (skip tiny snippets).
RAW_TEXT_MIN_CHARS=100
